# Secrets untuk Supabase Edge Functions (create-payment & payment-webhook)
# Set lewat: supabase secrets set NAMA=nilai
# JANGAN commit file .env asli — ini hanya contoh/referensi.

SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=isi-service-role-key
APP_URL=https://username.github.io/bank-soal-app

MIDTRANS_SERVER_KEY=isi-midtrans-server-key-sandbox-atau-produksi
XENDIT_SECRET_KEY=isi-xendit-secret-key
XENDIT_WEBHOOK_TOKEN=isi-xendit-verification-token
